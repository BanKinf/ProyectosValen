---

---
<header class="container">
    <div id="particles-js"></div>
    <div class="typewriter">
        <h1>Hi! I'm Valentina Werle</h1>
    </div>
    <p>A software developer from Argentina</p>
    <button class="btn_temp">My Resume</button>
</header>

<script is:inline src="src/particles.js"></script>
<script is:inline src="src/app.js"></script>

<!-- typewriter -->
<style>
    .typewriter h1 {
        overflow: hidden;
        border-right: .15em solid #F797FC; 
        white-space: nowrap; 
        margin: 0 auto; 
        animation: 
            typing 3.5s steps(40, end),
            blink-caret .75s step-end infinite;
    }

    @keyframes typing {
        from { width: 0 }
        to { width: 100% }
    }
  
    @keyframes blink-caret {
        from, to { border-color: transparent }
        50% { border-color: #F797FC; }
    }
    
</style>

<!-- header -->
<style>
    header {
        text-align: center;
        margin-bottom: 3rem;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;

    }

    header p {
        color: #9ca3af;
        margin-bottom: 1rem;
        padding: 20px 20px;
        font-size: 1.5rem;
        text-shadow: 4px 4px 6px #0008;
    }

</style>

<!-- particles -->
<style>
    #particles-js{
        width: 100%;
        height: 100%;
        background-color: #202430;
        background-image: url('');
        background-size: cover;
        background-position: 50% 50%;
        background-repeat: no-repeat;
        position: absolute;
        z-index: -1;
    }
</style>

<!-- h1 -->
<style>
    @import url('https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400..700&display=swap');

    h1, h2, h3 {
        margin-bottom: 1rem;
    }

    h1 {
        font-size: 4.0rem;
        font-family: "Pixelify Sans", sans-serif;
        font-weight: 400;
        letter-spacing: 2px;
        padding-bottom: 20px;
        text-shadow: 4px 4px 6px #0008;
    }
</style>

<!-- button -->
<style>
    .btn_temp {
        background-color: #202430;
        max-width: 150px;
        color: white;
        border-color: #F797FC;
        padding: 0.5rem 1rem;
        font-size: 1rem;
        cursor: pointer;
        border-radius: 0.25rem;
        transition: 0.3s;
        text-shadow: 4px 4px 6px #0005;
    }

    .btn_temp:hover {
        scale: 1.1;
    }
</style>