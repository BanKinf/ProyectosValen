---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Portafolio de Valentina Werle para demostrar habilidades en el desarollo web!" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body>
		<slot class="container"/>
	</body>
</html>
<style is:global>
	.container {
		max-width: 1024px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	* {
    	margin: 0;
    	padding: 0;
    	box-sizing: border-box;
	}

	html {
		font-family: system-ui, sans-serif;
		color: #ffffff;
		background: #202430;
	}
</style>
